# Reel48+ Backend Environment Variables
# Copy to .env and fill in values for local development

# Database (PostgreSQL 15+ with RLS support)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reel48
DATABASE_ECHO=false

# Redis (rate limiting, session caching)
REDIS_URL=redis://localhost:6379/0

# Amazon Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# CORS (frontend URL)
ALLOWED_ORIGINS=["http://localhost:3000"]

# Application
DEBUG=true
